msgstr "خبز يُخلط مع مرق اللحم والخضار، ويُقدَّم كطبق تقليدي مشبع."

#: .\main\templates\main\foods.html:227
msgid "Areekah"
msgstr "العريكة"

#: .\main\templates\main\foods.html:228
msgid "Dough mixed with dates and honey."
msgstr "عجين يُخلط مع التمر والعسل."

#: .\main\templates\main\foods.html:236
